{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".scope/hooks/scope-safety-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".scope/hooks/scope-spl-lint.sh"
          },
          {
            "type": "command",
            "command": ".scope/hooks/scope-schema-validate.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".scope/hooks/scope-agent-logger.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".scope/hooks/scope-artifact-check.sh"
          }
        ]
      }
    ]
  }
}
