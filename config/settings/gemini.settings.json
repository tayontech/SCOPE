{
  "mcpServers": {
    "splunk-mcp-server": {
      "command": "bash",
      "args": ["bin/splunk-mcp-start.sh"],
      "env": {
        "SPLUNK_URL": "$SPLUNK_URL",
        "SPLUNK_TOKEN": "$SPLUNK_TOKEN"
      }
    }
  },
  "context": {
    "fileName": ["AGENTS.md"]
  },
  "experimental": {
    "enableAgents": true
  },
  "tools": {
    "shell": {
      "inactivityTimeout": 1800000
    }
  },
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "run_shell_command",
        "hooks": [
          {
            "type": "command",
            "command": "__HOOKS_DIR__/scope-safety-guard.sh"
          },
          {
            "type": "command",
            "command": "__HOOKS_DIR__/scope-aws-output-inject.sh"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "write_file|replace",
        "hooks": [
          {
            "type": "command",
            "command": "__HOOKS_DIR__/scope-spl-lint.sh"
          },
          {
            "type": "command",
            "command": "__HOOKS_DIR__/scope-schema-validate.sh"
          }
        ]
      },
      {
        "matcher": "run_shell_command",
        "hooks": [
          {
            "type": "command",
            "command": "__HOOKS_DIR__/scope-agent-logger.sh"
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__HOOKS_DIR__/scope-artifact-check.sh"
          }
        ]
      }
    ]
  }
}
