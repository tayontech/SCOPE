# OS
.DS_Store

# Backups
*.bak

# Python
__pycache__/
*.pyc

# Editor configs (generated by install.js --local)
.claude/
.codex/
.gemini/
.agents/

.planning/


# Engagement output (generated at runtime)
engagements/

# Runtime output (generated by agents and middleware)
data/
evidence/
agent-logs/
audit/
defend/
exploit/
investigate/

# Dashboard
dashboard/node_modules/
dashboard/dist/
dashboard/public/*.json
dashboard/dashboard.html

# MCP configuration (may contain credentials)
.mcp.json

# Config (user-specific — contains real account IDs and policies)
config/accounts.json
config/scps/*.json
!config/scps/_example.json
